{
  "schema_version": 1,
  "queue_name": "ai-development-pending-tasks-example",
  "status": "example_only",
  "description": "Example queue for PR-based AI development tasks. Copy to a runtime or branch-specific queue before use.",
  "defaults": {
    "target_base_branch": "main",
    "branch_prefix": "ai-dev/",
    "max_changed_files": 12,
    "requires_pull_request": true,
    "allow_direct_main_push": false,
    "allow_production_commands": false,
    "allow_line_notifications": false,
    "allow_trading_execution": false
  },
  "blocked_paths": [
    ".env",
    "data/stock_analysis.db",
    "data/backups/",
    "analysis/output/"
  ],
  "blocked_keywords": [
    "send_line_report(",
    "line_bot_api.push_message",
    "api.place_order",
    "place_order(",
    "run_pipeline("
  ],
  "tasks": [
    {
      "task_id": "AI-DEV-EXAMPLE-001",
      "status": "pending",
      "priority": 100,
      "risk_level": "low",
      "target_base_branch": "main",
      "branch_name": "ai-dev/ai-dev-example-001",
      "objective": "Add a low-risk validation or documentation improvement without touching production runtime behavior.",
      "allowed_paths": [
        "docs/",
        "tests/",
        "scripts/orchestrator/",
        "orchestrator/queue/"
      ],
      "blocked_paths": [
        ".env",
        "data/stock_analysis.db",
        "data/backups/",
        "analysis/output/"
      ],
      "validation_commands": [
        "python3 scripts/orchestrator/validate_ai_branch.py --base main --head HEAD --pretty",
        "python3 scripts/orchestrator/check_forbidden_changes.py --base main --head HEAD --pretty"
      ],
      "success_criteria": [
        "All changed files are within allowed paths.",
        "No blocked paths are changed.",
        "No blocked production, LINE, or trading keywords are introduced.",
        "Validation report is attached to the pull request summary."
      ]
    }
  ]
}
